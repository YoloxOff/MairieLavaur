{
  "name": "site-ville-de-lavaur",
  "version": "0.1.0",
  "private": true,
  "description": "Refonte du site internet de la Ville de Lavaur - theme WordPress sur-mesure",
  "scripts": {
    "dev": "tailwindcss -i ./wp-content/themes/lavaur/assets/src/input.css -o ./wp-content/themes/lavaur/assets/dist/style.css --watch",
    "build": "tailwindcss -i ./wp-content/themes/lavaur/assets/src/input.css -o ./wp-content/themes/lavaur/assets/dist/style.css --minify",
    "playground": "wp-playground server --php=8.3 --wp=6.7 --mount-dir ./wp-content/themes/lavaur /wordpress/wp-content/themes/lavaur --blueprint=./playground/blueprint.json --blueprint-may-read-adjacent-files --port=9400"
  },
  "devDependencies": {
    "@wp-playground/cli": "^3.1.43",
    "tailwindcss": "^3.4.13"
  },
  "dependencies": {
    "alpinejs": "^3.14.1"
  }
}
